/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MPU Configuration--------------------------------------------------------*/
  MPU_Config();

  /* Enable the CPU Cache */

  /* Enable I-Cache---------------------------------------------------------*/
  SCB_EnableICache();

  /* Enable D-Cache---------------------------------------------------------*/
  SCB_EnableDCache();

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
STM32CubeAI_Studio_AI_Init();
  
  /* USER CODE BEGIN 2 */
stai_ptr network = NULL;
   stai_mnetwork_init(STAI_NETWORK_MODEL_NAME, &network);
   stai_mnetwork_set_activations(network, (const stai_ptr *)data_activations);
   stai_mnetwork_set_states(network,      (const stai_ptr *)data_states);
   stai_mnetwork_set_inputs(network,      (const stai_ptr *)data_ins);
   stai_mnetwork_set_outputs(network,     (const stai_ptr *)data_outs);

   float total_loss    = 0.0f;
   float total_sq_loss = 0.0f;
   uint32_t total_time     = 0;
   uint32_t runs_completed = 0;

   printf("Sine Wave Prediction\r\n\n");

   for (int i = 0; i < NUM_INPUTS; i++)
   {
       float current_angle = (float)i * (2.0f * (float)M_PI) / (float)(NUM_INPUTS - 1);
       if (current_angle > 2.0f * (float)M_PI)
           current_angle = 2.0f * (float)M_PI;

       printf("Test case %d: ", i + 1);
       printf("Input = %.4f rad (%.2f deg)\n",
              current_angle,
              current_angle * 180.0f / (float)M_PI);

       memcpy(data_ins[0], &current_angle, sizeof(float));

       uint32_t start_time = getCurrentMicros();
       stai_mnetwork_run(network);
       uint32_t inference_time = getCurrentMicros() - start_time;

       float output_val = 0.0f;
       memcpy(&output_val, data_outs[0], sizeof(float));

       float ground_truth = sinf(current_angle);
       float error        = ground_truth - output_val;

       total_loss    += fabsf(error);
       total_sq_loss += error * error;
       total_time    += inference_time;
       runs_completed++;

       uint8_t led_state = Switch_Led(output_val);
       const char *led_str;
       if (output_val > 0.1f)
           led_str = "Positive: Green LED ON";
       else if (output_val < -0.1f)
           led_str = "Negative: Red LED ON";
       else
           led_str = "Intersecting Zero: Both LEDs OFF";

       printf("Output = [%.6f  %.6f  %+.6f] > %s\n\n",
              output_val, ground_truth, error, led_str);

       printf("Inference time: %lu us\r\n\r\n", inference_time);

       HAL_Delay(1000);
   }

   if (runs_completed > 0)
   {
       uint32_t average_time = total_time / runs_completed;
       float mae  = total_loss    / (float)runs_completed;
       float mse  = total_sq_loss / (float)runs_completed;
       float rmse = sqrtf(mse);

       printf("  Average time   : %lu us\r\n", average_time);
       printf("  MAE  (Mean Absolute Error): %.6f\r\n", mae);
       printf("  MSE  (Mean Squared Error): %.6f\r\n", mse);
       printf("  RMSE (Root Mean Squared Error): %.6f\r\n", rmse);
   }
   else
   {
       printf("  No valid inference tests complete\r\n");
   }

   printf("\n  %d Inference tests complete\r\n", NUM_INPUTS);

   // Turn off LEDs.
   HAL_GPIO_WritePin(LD1_GPIO_Port, LD1_Pin, GPIO_PIN_RESET);
   HAL_GPIO_WritePin(LD3_GPIO_Port, LD3_Pin, GPIO_PIN_RESET);
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

