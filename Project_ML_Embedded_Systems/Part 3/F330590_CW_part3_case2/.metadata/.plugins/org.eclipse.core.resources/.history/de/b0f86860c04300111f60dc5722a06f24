static float current_angle = 0.0f;
uint8_t UseCase = 0;
uint32_t start_time = 0;
uint32_t end_time   = 0;
uint32_t inference_time = 0;
uint32_t total_time     = 0;
float    total_loss     = 0.0f;
float    total_sq_loss  = 0.0f;


uint8_t Switch_Led(ai_float predicted_sine)
{
    uint8_t u8Result = 0;

    if (predicted_sine > 0.1f)
    {
        /* When the sine wave is positive: Green LED ON, Red LED OFF */
        HAL_GPIO_WritePin(LD1_GPIO_Port, LD1_Pin, GPIO_PIN_SET);
        HAL_GPIO_WritePin(LD3_GPIO_Port, LD3_Pin, GPIO_PIN_RESET);
        u8Result = 1;
    }
    else if (predicted_sine < -0.1f)
    {
        /* When the sine wave is negative: Red LED ON, Green LED OFF */
        HAL_GPIO_WritePin(LD1_GPIO_Port, LD1_Pin, GPIO_PIN_RESET);
        HAL_GPIO_WritePin(LD3_GPIO_Port, LD3_Pin, GPIO_PIN_SET);
        u8Result = 2;
    }
    else
    {
        /* When the sine wave intersects at 0: both LEDs OFF */
        HAL_GPIO_WritePin(LD1_GPIO_Port, LD1_Pin, GPIO_PIN_RESET);
        HAL_GPIO_WritePin(LD3_GPIO_Port, LD3_Pin, GPIO_PIN_RESET);
        u8Result = 0;
    }

    return u8Result;
}

ai_float* Set_arrOutData(ai_i8 out_data[], ai_float arrOut_data[], float input_angle)
{
    /* [0] = predicted sine value from the network */
    arrOut_data[0] = ((ai_float *)out_data)[0];

    /* [1] = ground truth sine for comparison */
    arrOut_data[1] = sinf(input_angle);

    /* [2] = absolute error */
    arrOut_data[2] = arrOut_data[1] - arrOut_data[0];

    return arrOut_data;
}

char* Led_State_As_String(uint8_t led_status, char out_info[])
{
    if (led_status == 0)
    {
        strcpy(out_info, "ZERO CROSSING: Both LEDs OFF");
    }
    else if (led_status == 1)
    {
        strcpy(out_info, "POSITIVE: Green LED ON");
    }
    else if (led_status == 2)
    {
        strcpy(out_info, "NEGATIVE: Red LED ON");
    }
    return out_info;
}

int acquire_and_process_data(ai_i8* data[])
{
    current_angle = (float)UseCase * (2.0f * (float)M_PI) / (float)(NUM_TEST_POINTS - 1);


    if (current_angle > 2.0f * (float)M_PI)
        current_angle = 2.0f * (float)M_PI;


    ((ai_float *)data[0])[0] = (ai_float)current_angle;

    printf("Use case %d:", UseCase + 1);
    printf("Input = angle=%.4f rad (%.2f deg)\n",
           current_angle,
           current_angle * 180.0f / (float)M_PI);

    return 0;
}
int post_process(ai_i8* data[])
{
    char     sOutInfo[64] = {0};
    ai_float arrOutData[3];

    Set_arrOutData(data[0], arrOutData, current_angle);

    uint8_t led_state = Switch_Led(arrOutData[0]);

    printf("Output = [%.6f  %.6f  %+.6f] > %s\n\n",
           arrOutData[0],
           arrOutData[1],
           arrOutData[2],
           Led_State_As_String(led_state, sOutInfo));

    // Accumulate absolute error and squared error for MAE and MSE.
    total_loss    += fabsf(arrOutData[2]);
    total_sq_loss += arrOutData[2] * arrOutData[2];

    return 0;
}
