void MX_X_CUBE_AI_Process(void)
{
    /* USER CODE BEGIN 6 */
    int res = -1;
    uint32_t runs_completed = 0;
    UseCase    = 0;
    total_time = 0;
    total_loss    = 0.0f;
    total_sq_loss = 0.0f;

    printf("###############################################################\r\n");
    printf("###         Sine Wave Prediction - sine_model.tflite        ###\r\n");
    printf("###  Input : angle (radians)  Output : sin(angle)           ###\r\n");
    printf("###############################################################\r\n\r\n");

    if (network)
    {
        do {
            res = acquire_and_process_data(data_ins);

            if (res == 0)
            {
                start_time = getCurrentMicros();
                res = ai_run();
                end_time = getCurrentMicros();
                inference_time = end_time - start_time;
            }
                if (res == 0)
                {
                    inference_time = end_time - start_time;
                    total_time    += inference_time;
                    runs_completed++;
                }


            if (res == 0)
            {
                res = post_process(data_outs);
            }

            printf("Inference time: %lu us\r\n\r\n", inference_time);

            HAL_Delay(1000);
            UseCase++;

        } while ((res == 0) && (UseCase < NUM_TEST_POINTS));
    }

    if (res) {
        ai_error err = {AI_ERROR_INVALID_STATE, AI_ERROR_CODE_NETWORK};
        ai_log_err(err, "Process has FAILED");
    }

    if (runs_completed > 0)
    {
        uint32_t average_time = total_time / runs_completed;
        printf("  Average time   : %lu us\r\n", average_time);

        float mae = total_loss / (float)runs_completed;
        float mse = total_sq_loss / (float)runs_completed;
        float rmse = sqrtf(mse);

        printf("  MAE  (Mean Absolute Error): %.6f\r\n", mae);
        printf("  MSE  (Mean Squared Error): %.6f\r\n", mse);
        printf("  RMSE (Root Mean Squared Error): %.6f\r\n", rmse);
    }
    else
    {
        printf("  Average time   : N/A (no successful runs)\r\n");
    }

    printf("\n%d Inference tests complete.\r\n", NUM_TEST_POINTS);

    /* Turn off LEDs */
    HAL_GPIO_WritePin(LD1_GPIO_Port, LD1_Pin, GPIO_PIN_RESET);
    HAL_GPIO_WritePin(LD3_GPIO_Port, LD3_Pin, GPIO_PIN_RESET);

    /* Idle here so main()'s while(1) does not restart this function */
    while (1)
    {
        HAL_Delay(5000);
    }
    /* USER CODE END 6 */
}
